# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# External APIs
FOURSQUARE_API_KEY=your-foursquare-key
MAPBOX_API_KEY=your-mapbox-token

# Stripe (for later)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App
SECRET_KEY=generate-random-32-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Renderer backend (Phase 6C)
RENDER_BACKEND=local
RENDERER_URL=http://localhost:3100
AWS_REGION=us-east-1
AWS_WORKER_ROLE_ARN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LAMBDA_FUNCTION_NAME=
LAMBDA_SERVE_URL=
LAMBDA_OUTPUT_BUCKET=
EXPORT_WORKER_STALE_SECONDS=1200
# Optional override; defaults to 3.0s in lambda mode and 0.05s in local mode.
EXPORT_RENDER_POLL_SECONDS=3.0
EXPORT_MAX_CONCURRENT_PER_USER=2
EXPORT_GLOBAL_QUEUE_CAP=50
EXPORT_FREE_TIER_MAX_QUALITY=720p
EXPORT_FREE_TIER_MAX_DURATION_SEC=15
