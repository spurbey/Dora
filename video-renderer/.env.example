# Renderer service
PORT=3100
RENDER_BACKEND=local
RENDER_OUTPUT_DIR=./render_artifacts

# Optional local Chrome override
# REMOTION_CHROME_EXECUTABLE=/path/to/chrome

# Lambda mode (6C)
AWS_REGION=us-east-1
LAMBDA_FUNCTION_NAME=
LAMBDA_SERVE_URL=
LAMBDA_OUTPUT_BUCKET=
LAMBDA_MEMORY_MB=2048
LAMBDA_TIMEOUT_SECONDS=900
LAMBDA_DISK_MB=2048
LAMBDA_ARCHITECTURE=arm64
LAMBDA_SITE_NAME=dora-classic
